<Window x:Class="KeeperPRO.Views.RequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление пропуска" Height="650" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FF2B5797" Padding="15">
            <StackPanel>
                <TextBlock Text="ХранительПРО" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Система оформления пропусков" FontSize="12" Foreground="#CCFFFFFF"/>
            </StackPanel>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Новая заявка">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Тип заявки" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbRequestType" Width="200" Margin="0,0,0,15" SelectedIndex="0">
                            <ComboBoxItem Content="Личная"/>
                            <ComboBoxItem Content="Групповая"/>
                        </ComboBox>

                        <GroupBox Header="Информация о пропуске" Margin="0,10">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата начала:" VerticalAlignment="Center"/>
                                <DatePicker x:Name="dpStartDate" Grid.Row="0" Grid.Column="1" Width="200" SelectedDate="{Binding StartDate}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата окончания:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <DatePicker x:Name="dpEndDate" Grid.Row="1" Grid.Column="1" Width="200" Margin="0,10,0,0"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Принимающая сторона" Margin="0,10">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Подразделение:" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbDepartment" Grid.Row="0" Grid.Column="1" SelectionChanged="cmbDepartment_SelectionChanged"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Сотрудник:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                <ComboBox x:Name="cmbEmployee" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" DisplayMemberPath="full_name" SelectedValuePath="employee_id"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Цель посещения" Margin="0,10">
                            <TextBox x:Name="txtPurpose" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="10"/>
                        </GroupBox>

                        <Button x:Name="btnSubmit" Content="Подать заявку" Width="200" Height="40" 
                                Background="#FF4CAF50" Foreground="White" FontWeight="Bold"
                                Click="btnSubmit_Click" Margin="0,10,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Мои заявки">
                <DataGrid x:Name="dgvRequests" AutoGenerateColumns="True" Margin="10"/>
            </TabItem>
        </TabControl>

        <!-- Кнопка выхода -->
        <Button x:Name="btnLogout" Grid.Row="2" Content="Выход" Width="100" Height="35" 
                HorizontalAlignment="Right" Margin="0,10,20,10"
                Background="#FFE74C3C" Foreground="White" Click="btnLogout_Click"/>
    </Grid>
</Window>