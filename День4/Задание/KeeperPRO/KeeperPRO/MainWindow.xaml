<Window x:Class="KeeperPRO.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ХранительПРО" Height="450" Width="600"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF2B5797" Offset="0"/>
            <GradientStop Color="#FF1E3A6F" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="ХранительПРО" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock Text="Система контроля физического доступа" FontSize="14" Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,0,0,40"/>

        <Button x:Name="btnLogin" Content="Вход в систему" Width="250" Height="45" Margin="0,10" 
                FontSize="14" FontWeight="Bold" Background="#FF4CAF50" Foreground="White"
                Click="btnLogin_Click" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>

        <Button x:Name="btnRegister" Content="Регистрация" Width="250" Height="45" Margin="0,10" 
                FontSize="14" FontWeight="Bold" Background="#FF2196F3" Foreground="White"
                Click="btnRegister_Click" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </StackPanel>
</Window>