<Window x:Class="KeeperPRO.Security.Views.SecurityMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал охраны - ХранительПРО" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF2B5797" Padding="15">
            <StackPanel>
                <TextBlock Text="Терминал сотрудника охраны" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="ХранительПРО - контроль доступа" FontSize="12" Foreground="#CCFFFFFF"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FFF0F0F0" Padding="10">
            <StackPanel>
                <TextBlock Text="Фильтрация заявок" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Дата:"/>
                        <DatePicker x:Name="dpFilterDate" SelectedDate="{x:Null}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Тип:"/>
                        <ComboBox x:Name="cmbFilterType" SelectedIndex="0">
                            <ComboBoxItem Content="Все"/>
                            <ComboBoxItem Content="Личная"/>
                            <ComboBoxItem Content="Групповая"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Подразделение:"/>
                        <ComboBox x:Name="cmbFilterDepartment" DisplayMemberPath="name" SelectedValuePath="department_id"/>
                    </StackPanel>

                    <Button x:Name="btnFilter" Grid.Column="3" Content="Применить" Width="100" Height="30" 
                            Margin="5,20,0,0" Click="btnFilter_Click" Background="#FF2196F3" Foreground="White"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#FFF8F8F8" Padding="10" BorderBrush="#FFDDDDDD" BorderThickness="0,1,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtSearch" Grid.Column="0" Height="30" VerticalContentAlignment="Center"/>
                <Button x:Name="btnSearch" Grid.Column="1" Content="Поиск" Width="80" Height="30" Margin="10,0,0,0" 
                        Click="btnSearch_Click" Background="#FF4CAF50" Foreground="White"/>
            </Grid>
        </Border>

        <DataGrid x:Name="dgvRequests" Grid.Row="3" Margin="10" AutoGenerateColumns="True" 
                  SelectionChanged="dgvRequests_SelectionChanged" IsReadOnly="True"/>

        <Button x:Name="btnLogout" Grid.Row="4" Content="Выход" Width="100" Height="35" 
                HorizontalAlignment="Right" Margin="0,10,20,10"
                Background="#FFE74C3C" Foreground="White" Click="btnLogout_Click"/>
    </Grid>
</Window>