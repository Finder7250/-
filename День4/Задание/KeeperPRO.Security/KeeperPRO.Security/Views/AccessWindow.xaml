<Window x:Class="KeeperPRO.Security.Views.AccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление доступом" Height="600" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление доступом посетителя" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <GroupBox Grid.Row="1" Header="Данные заявки" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtType" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Подразделение:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtDepartment" Margin="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата посещения:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtVisitDate" Margin="5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Цель:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtPurpose" Margin="5" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Данные посетителя" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="ФИО:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtVisitorName" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Паспорт:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtPassport" Margin="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Телефон:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtPhone" Margin="5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Email:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtEmail" Margin="5"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Время доступа" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Время входа:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtAccessStart" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Время выхода:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtAccessEnd" Margin="5"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="Управление доступом" Margin="0,5">
            <StackPanel Margin="10">
                <Button x:Name="btnGrantAccess" Content="РАЗРЕШИТЬ ДОСТУП" Height="50" FontSize="16" FontWeight="Bold"
                        Background="#FF4CAF50" Foreground="White" Click="btnGrantAccess_Click" Margin="0,5"/>
                <TextBlock x:Name="txtAccessStatus" Foreground="Green" TextAlignment="Center" Margin="0,5"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="Фиксация убытия" Margin="0,5">
            <StackPanel Margin="10">
                <Button x:Name="btnSetDeparture" Content="ЗАФИКСИРОВАТЬ ВЫХОД" Height="40" FontSize="14" FontWeight="Bold"
                        Background="#FF2196F3" Foreground="White" Click="btnSetDeparture_Click" Margin="0,5"/>
                <TextBlock x:Name="txtDepartureStatus" Foreground="Blue" TextAlignment="Center" Margin="0,5"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>