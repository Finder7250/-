<Window x:Class="KeeperPRO.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="500" Width="500"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF2B5797" Offset="0"/>
            <GradientStop Color="#FF1E3A6F" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
        <TextBlock Text="Регистрация" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Text="Email" Foreground="White" Margin="0,5,0,3"/>
        <TextBox x:Name="txtEmail" Height="35" FontSize="14"/>

        <TextBlock Text="Пароль" Foreground="White" Margin="0,10,0,3"/>
        <PasswordBox x:Name="txtPassword" Height="35" FontSize="14"/>
        <TextBlock Text="(не менее 8 символов, цифра, спецсимвол, верхний и нижний регистр)" 
                   Foreground="#CCFFFFFF" FontSize="10" Margin="0,2,0,0"/>

        <TextBlock Text="Подтверждение пароля" Foreground="White" Margin="0,10,0,3"/>
        <PasswordBox x:Name="txtConfirmPassword" Height="35" FontSize="14"/>

        <Button x:Name="btnRegister" Content="Зарегистрироваться" Height="40" FontSize="14" FontWeight="Bold" 
                Background="#FF4CAF50" Foreground="White" Margin="0,20,0,0" Click="btnRegister_Click"/>

        <Button x:Name="btnBack" Content="Назад" Height="35" FontSize="12" 
                Background="Transparent" Foreground="#CCFFFFFF" 
                BorderBrush="#CCFFFFFF" BorderThickness="1" Margin="0,10,0,0" Click="btnBack_Click"/>
    </StackPanel>
</Window>