<Window x:Class="KeeperPRO.GeneralDepartment.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал общего отдела" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF2B5797" Offset="0"/>
            <GradientStop Color="#FF1E3A6F" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="320">
        <TextBlock Text="Терминал сотрудника общего отдела" FontSize="20" FontWeight="Bold" Foreground="White" 
                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
        <TextBlock Text="ХранительПРО" FontSize="14" Foreground="#CCFFFFFF" HorizontalAlignment="Center" Margin="0,10,0,30"/>

        <TextBlock Text="Код сотрудника" Foreground="White" Margin="0,10,0,5"/>
        <PasswordBox x:Name="txtEmployeeCode" Height="35" FontSize="14"/>

        <Button x:Name="btnLogin" Content="Войти" Height="40" FontSize="14" FontWeight="Bold" 
                Background="#FF4CAF50" Foreground="White" Margin="0,20,0,0" Click="btnLogin_Click"/>
    </StackPanel>
</Window>