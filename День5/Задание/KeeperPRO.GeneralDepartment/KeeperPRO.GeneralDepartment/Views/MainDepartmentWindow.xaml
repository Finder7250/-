<Window x:Class="KeeperPRO.GeneralDepartment.Views.MainDepartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал общего отдела - ХранительПРО" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF2B5797" Padding="15">
            <StackPanel>
                <TextBlock Text="Терминал сотрудника общего отдела" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="ХранительПРО - проверка заявок на пропуск" FontSize="12" Foreground="#CCFFFFFF"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FFF0F0F0" Padding="10">
            <StackPanel>
                <TextBlock Text="Фильтрация заявок" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Тип:"/>
                        <ComboBox x:Name="cmbFilterType" SelectedIndex="0">
                            <ComboBoxItem Content="Все"/>
                            <ComboBoxItem Content="Личная"/>
                            <ComboBoxItem Content="Групповая"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Подразделение:"/>
                        <ComboBox x:Name="cmbFilterDepartment" DisplayMemberPath="name" SelectedValuePath="department_id"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Статус:"/>
                        <ComboBox x:Name="cmbFilterStatus" SelectedIndex="0">
                            <ComboBoxItem Content="Все"/>
                            <ComboBoxItem Content="проверка"/>
                            <ComboBoxItem Content="одобрена"/>
                            <ComboBoxItem Content="не одобрена"/>
                        </ComboBox>
                    </StackPanel>

                    <Button x:Name="btnFilter" Grid.Column="3" Content="Применить" Width="100" Height="30" 
                            Margin="5,20,0,0" Click="btnFilter_Click" Background="#FF2196F3" Foreground="White"/>
                </Grid>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgvRequests" Grid.Row="2" Margin="10" AutoGenerateColumns="True" 
                  SelectionChanged="dgvRequests_SelectionChanged" IsReadOnly="True"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,10">
            <Button x:Name="btnReports" Content="📊 Отчеты" Width="100" Height="35" 
                    Background="#FF9C27B0" Foreground="White" Click="btnReports_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnLogout" Content="Выход" Width="100" Height="35" 
                    Background="#FFE74C3C" Foreground="White" Click="btnLogout_Click"/>
        </StackPanel>
    </Grid>
</Window>