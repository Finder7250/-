<Window x:Class="KeeperPRO.GeneralDepartment.Views.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчеты" Height="700" Width="1000"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Статистика посещений">
                <StackPanel Margin="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Период:" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox x:Name="cmbPeriod" Grid.Column="1" Width="150" Margin="5" SelectedIndex="0">
                            <ComboBoxItem Content="День"/>
                            <ComboBoxItem Content="Месяц"/>
                            <ComboBoxItem Content="Год"/>
                        </ComboBox>
                        <Button x:Name="btnLoadStats" Grid.Column="2" Content="Загрузить" Width="100" 
                                Click="btnLoadStats_Click" Background="#FF2196F3" Foreground="White"/>
                    </Grid>
                    <DataGrid x:Name="dgvStats" Margin="0,10" AutoGenerateColumns="True" Height="400"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>