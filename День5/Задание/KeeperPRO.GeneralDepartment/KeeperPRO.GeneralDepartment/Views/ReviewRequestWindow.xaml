<Window x:Class="KeeperPRO.GeneralDepartment.Views.ReviewRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Формальная проверка заявки" Height="650" Width="750"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Формальная проверка заявки" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <GroupBox Grid.Row="1" Header="Данные заявки" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtType" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Цель:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtPurpose" Margin="5" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Подразделение:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtDepartment" Margin="5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Сотрудник:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtEmployee" Margin="5"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата создания:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtCreatedAt" Margin="5"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Данные посетителя" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="ФИО:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtVisitorName" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Паспорт:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtPassport" Margin="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата рождения:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtBirthDate" Margin="5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Телефон:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtPhone" Margin="5"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Email:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtEmail" Margin="5"/>
            </Grid>
        </GroupBox>

        <Border Grid.Row="3" Background="#FFFFE0" Padding="10" Margin="0,10" CornerRadius="5">
            <TextBlock x:Name="txtBlacklistStatus" TextWrapping="Wrap"/>
        </Border>

        <GroupBox Grid.Row="4" Header="Управление заявкой" Margin="0,5" x:Name="gbControls">
            <StackPanel Margin="10">
                <TextBlock Text="Дата посещения:" Margin="0,0,0,5"/>
                <DatePicker x:Name="dpVisitDate" Width="200" Margin="0,0,0,10"/>

                <TextBlock Text="Статус:" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbStatus" Width="200" Margin="0,0,0,10" SelectionChanged="cmbStatus_SelectionChanged">
                    <ComboBoxItem Content="одобрена"/>
                    <ComboBoxItem Content="не одобрена"/>
                </ComboBox>

                <TextBlock Text="Причина отклонения:" Margin="0,0,0,5" x:Name="lblRejectionReason"/>
                <TextBox x:Name="txtRejectionReason" Height="60" TextWrapping="Wrap" IsEnabled="False"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35" 
                    Background="#FF4CAF50" Foreground="White" Click="btnSave_Click" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>