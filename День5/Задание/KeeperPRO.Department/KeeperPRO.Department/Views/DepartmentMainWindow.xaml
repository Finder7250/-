<Window x:Class="KeeperPRO.Department.Views.DepartmentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал подразделения - ХранительПРО" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF2B5797" Padding="15">
            <StackPanel>
                <TextBlock Text="Терминал сотрудника подразделения" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="ХранительПРО - управление посещениями" FontSize="12" Foreground="#CCFFFFFF"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FFF0F0F0" Padding="10">
            <StackPanel>
                <TextBlock Text="Фильтрация заявок по дате" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="dpFilterDate" Grid.Column="0" Width="200" SelectedDate="{x:Null}"/>
                    <Button x:Name="btnFilter" Grid.Column="1" Content="Применить" Width="100" Height="30" 
                            Margin="10,0,110,0" Click="btnFilter_Click" Background="#FF2196F3" Foreground="White"/>
                    <Button x:Name="btnReset" Grid.Column="1" Content="Сброс" Width="100" Height="30" 
                            Margin="120,0,0,0" Click="btnReset_Click" Background="#FF9800" Foreground="White"/>
                </Grid>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgvRequests" Grid.Row="2" Margin="10" AutoGenerateColumns="True" 
                  SelectionChanged="dgvRequests_SelectionChanged" IsReadOnly="True"/>

        <Button x:Name="btnLogout" Grid.Row="3" Content="Выход" Width="100" Height="35" 
                HorizontalAlignment="Right" Margin="0,10,20,10"
                Background="#FFE74C3C" Foreground="White" Click="btnLogout_Click"/>
    </Grid>
</Window>