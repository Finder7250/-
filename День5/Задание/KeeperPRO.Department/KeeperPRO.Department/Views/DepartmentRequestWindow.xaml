<Window x:Class="KeeperPRO.Department.Views.DepartmentRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали заявки" Height="700" Width="850"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Детали заявки на посещение" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Данные заявки -->
        <GroupBox Grid.Row="1" Header="Данные заявки" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtType" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата посещения:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtVisitDate" Margin="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Цель:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtPurpose" Margin="5" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Статус:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtStatus" Margin="5"/>
            </Grid>
        </GroupBox>

        <!-- Список посетителей -->
        <GroupBox Grid.Row="2" Header="Список посетителей (ПКМ для добавления в черный список)" Margin="0,5">
            <DataGrid x:Name="dgvVisitors" AutoGenerateColumns="True" Height="180" Margin="5"/>
        </GroupBox>

        <!-- Время прибытия/убытия -->
        <GroupBox Grid.Row="3" Header="Время прибытия/убытия" Margin="0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Время прибытия:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtCheckIn" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Время убытия:" FontWeight="Bold" Margin="5"/>
                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="txtCheckOut" Margin="5"/>
            </Grid>
        </GroupBox>

        <!-- Управление -->
        <GroupBox Grid.Row="4" Header="Управление" Margin="0,5">
            <StackPanel Margin="10">
                <Button x:Name="btnCheckIn" Content="ЗАФИКСИРОВАТЬ ПРИБЫТИЕ" Height="45" FontSize="14" FontWeight="Bold"
                        Background="#FF4CAF50" Foreground="White" Click="btnCheckIn_Click" Margin="0,5"/>
                <Button x:Name="btnCheckOut" Content="ЗАФИКСИРОВАТЬ УБЫТИЕ" Height="45" FontSize="14" FontWeight="Bold"
                        Background="#FF2196F3" Foreground="White" Click="btnCheckOut_Click" Margin="0,5"/>
            </StackPanel>
        </GroupBox>

        <!-- Информация о черном списке -->
        <GroupBox Grid.Row="5" Header="Информация" Margin="0,5">
            <StackPanel Margin="10">
                <TextBlock Text="💡 Чтобы добавить посетителя в черный список:" 
                           Foreground="Gray" FontSize="12"/>
                <TextBlock Text="   1. Выберите посетителя в таблице выше" 
                           Foreground="Gray" FontSize="12"/>
                <TextBlock Text="   2. Нажмите правую кнопку мыши" 
                           Foreground="Gray" FontSize="12"/>
                <TextBlock Text="   3. Выберите 'Добавить в черный список'" 
                           Foreground="Gray" FontSize="12"/>
            </StackPanel>
        </GroupBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>